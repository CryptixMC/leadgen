SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=
SMTP_FROM="Liam Nicholson <you@yourdomain.com>"
SMTP_SIGNATURE_URL=https://yoursite.vercel.app/signature.png

# Gemini AI (for email draft generation — model is gemini-2.0-flash)
GEMINI_API_KEY=
