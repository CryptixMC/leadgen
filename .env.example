# Server-side only (never exposed to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_PAGESPEED_API_KEY=
YELP_API_KEY=

# Public (safe to expose to browser)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Email / SMTP (Proton Mail Bridge: host=127.0.0.1 port=1025 for local dev)
# For Vercel production use Proton for Business SMTP or any other relay
SMTP_HOST=smtp.proton.me
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Gemini AI (for email draft generation — model is gemini-1.5-flash)
GEMINI_API_KEY=
